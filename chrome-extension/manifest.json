{
  "manifest_version": 3,

  "name": "Phishing Detector",

  "version": "2.0",

  "description": "AI-powered real-time phishing detection and blocking extension",

  "permissions": [
    "tabs"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Phishing Detector"
  }
}