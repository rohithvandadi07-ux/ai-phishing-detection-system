{
  "manifest_version": 3,

  "name": "AI Phishing Shield",

  "version": "1.0",

  "description": "AI-powered phishing detection extension",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "https://ai-phishing-detection-system-y2dn.onrender.com/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}