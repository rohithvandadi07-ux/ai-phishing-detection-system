{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "2.0",
  "description": "Real-time phishing blocker",

  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}