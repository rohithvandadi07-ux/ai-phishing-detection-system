{
  "manifest_version": 3,

  "name": "AI Phishing Shield",

  "description": "AI-powered real-time phishing detection and browser protection platform.",

  "version": "1.0.0",

  "permissions": [
  "tabs",
  "storage",
  "activeTab",
  "scripting",
  "notifications"
],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Phishing Shield"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "blocker.html",
        "scanning.html",
        "scanning.css",
        "scanning.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}