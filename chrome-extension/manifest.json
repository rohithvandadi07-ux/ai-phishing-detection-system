{
  "manifest_version": 3,

  "name": "AI Phishing Shield",

  "version": "2.1.0",

  "description": "AI-powered real-time phishing detection and malicious website blocking extension.",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://ai-phishing-detection-system-y2dn.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Phishing Shield"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}